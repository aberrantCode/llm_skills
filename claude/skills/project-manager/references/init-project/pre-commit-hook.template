#!/usr/bin/env sh
# .git/hooks/pre-commit
# Installed by /init-project. Calls the project-manager guard script.

set -e

if [ -f scripts/guard-pm-flow.ps1 ]; then
    if command -v pwsh >/dev/null 2>&1; then
        pwsh -NoProfile -File scripts/guard-pm-flow.ps1
    elif command -v powershell >/dev/null 2>&1; then
        powershell -NoProfile -File scripts/guard-pm-flow.ps1
    else
        echo "project-manager guard: PowerShell not found; skipping guard check." >&2
    fi
fi

exit 0
